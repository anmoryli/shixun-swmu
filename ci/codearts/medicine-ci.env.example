# Copy to /etc/medicine/medicine-ci.env on the deployment host.
# This file contains configuration only. Passwords stay in the secret files below.
MEDICINE_DB_URL=jdbc:mysql://MYSQL_HOST:3306/medicine?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MEDICINE_DB_USERNAME=medicine_app
MEDICINE_REDIS_HOST=REDIS_HOST
MEDICINE_REDIS_PORT=6379
MEDICINE_REDIS_DATABASE=0
MEDICINE_MYSQL_PASSWORD_FILE=/etc/medicine/secrets/mysql-password.txt
MEDICINE_REDIS_PASSWORD_FILE=/etc/medicine/secrets/redis-password.txt
MEDICINE_BIND_ADDRESS=0.0.0.0
MEDICINE_WEB_PORT=9092
MEDICINE_PROJECT_NAME=medicine-ci
