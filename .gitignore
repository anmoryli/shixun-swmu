# Temporary analysis and rendered source-review artifacts
.work/
ci-output/

# Runtime logs and process files
*.log
*.pid
logs/

# Java build and IDE output
**/target/
**/.idea/
**/*.iml

# Frontend dependencies and build output
**/node_modules/
**/dist/

# Runtime uploads and generated evidence staging
uploads/

# Local secrets and machine-specific overrides
**/.env.local
**/.env.*.local
**/application-local.yml
**/application-local.yaml
**/application-secrets.yml
**/application-secrets.yaml

# OS/editor files
.DS_Store
Thumbs.db
.vscode/
__pycache__/
*.py[cod]

# Docker Compose secrets must never be committed
deploy/docker/secrets/*
!deploy/docker/secrets/.gitkeep
