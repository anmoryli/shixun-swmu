# 同域部署推荐保持 /api；前后端分离时可填写完整网关地址。
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=10000
VITE_WITH_CREDENTIALS=true

# 仅供本地 vue-cli-service serve 使用。
VITE_PROXY_TARGET=http://localhost:8082

# 高德地图 Key（https://lbs.amap.com/ 控制台「应用管理」创建）
#   1) 添加 Key，服务平台选「Web端(JS API)」-> 得到 JS Key 与安全密钥
# JS Key 与安全密钥配合使用加载地图。
# 逆地理编码（Web 服务 Key）已由后端 /api/regeo 代理持有，前端无需配置。
# 请复制本文件为 .env.local 并填入真实值，.env.local 不会被提交。
VITE_AMAP_JS_KEY=your_web_js_api_key
VITE_AMAP_SECURITY_CODE=your_security_code
